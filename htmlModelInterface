function updateEtageUnit(diag) {
  const unit = DIAG_UNIT_MAP[diag] || '';
  const unitEl = document.getElementById('etg-unite');
  const litSel = document.getElementById('etg-lit');
  const occWrap = document.getElementById('etg-occ-bar-wrap');
  unitEl.value = unit ? UNIT_FULLNAMES_ADM[unit] : '';
  litSel.innerHTML = '<option value="">-- Choisir --</option>';
  // Hide map when unit changes
  const mapCard = document.getElementById('etg-map-card');
  if (mapCard) mapCard.style.display = 'none';
  if (!unit) return;
  const occupied = SIM.patients.filter(p=>p.unit===unit&&p.status==='ADMITTED').map(p=>p.bed);
  for (let i=1;i<=15;i++) {
    const opt = document.createElement('option');
    opt.value = i;
    const isFree = !occupied.includes(i);
    opt.textContent = 'Lit '+i+(isFree?' ✓ disponible':' — occupé');
    opt.disabled = !isFree;
    if (isFree) opt.style.color = '#16a34a';
    litSel.appendChild(opt);
  }
  // Occupation bar
  const pct = Math.round(occupied.length/15*100);
  const barColor = pct>=80?'#dc2626':pct>=65?'#d97706':'#3b8cc4';
  if (document.getElementById('etg-occ-bar-fill')) {
    document.getElementById('etg-occ-bar-fill').style.width = pct+'%';
    document.getElementById('etg-occ-bar-fill').style.background = barColor;
    document.getElementById('etg-occ-label').textContent = occupied.length+' lits occupés sur 15 ('+pct+'%) — '+(15-occupied.length)+' disponibles';
    if (occWrap) occWrap.style.display = 'block';
  }
  // Store current unit for bed map
  litSel._currentUnit = unit;
}

function renderAdmissionBedMap(unit, selectedBed) {
  const mapCard = document.getElementById('etg-map-card');
  const grid = document.getElementById('etg-map-grid');
  const titleEl = document.getElementById('etg-map-title');
  const descEl = document.getElementById('etg-map-desc');
  const badgeEl = document.getElementById('etg-map-badge');
  if (!mapCard || !grid) return;

  const unitNames = {'2N':'2e Nord — Cardiologie','2S':'2e Sud — Soins intensifs','3N':'3e Nord — Néphrologie','3S':'3e Sud — Médecine gén.'};
  const unitColors = {'2N':'#3b8cc4','2S':'#dc2626','3N':'#d97706','3S':'#0d9488'};
  const color = unitColors[unit] || 'var(--blue)';

  const patients = SIM.patients.filter(p=>p.unit===unit);
  const bedMap = {};
  patients.filter(p=>p.status==='ADMITTED').forEach(p=>bedMap[p.bed]=p);

  titleEl.textContent = 'Lit '+selectedBed+' — '+unitNames[unit];
  badgeEl.textContent = 'Lit '+selectedBed+' sélectionné';
  badgeEl.style.background = '#d1fae5';
  badgeEl.style.color = '#065f46';

  const freeCount = 15 - Object.keys(bedMap).length;
  descEl.innerHTML = '<strong style="color:'+color+'">'+unitNames[unit]+'</strong> · '+
    Object.keys(bedMap).length+' lits occupés · '+freeCount+' disponibles · ' +
    'Le lit <strong>'+selectedBed+'</strong> est mis en évidence ci-dessous en vert.';

  grid.innerHTML = '';
  for (let i=1;i<=15;i++) {
    const cell = document.createElement('div');
    const p = bedMap[i];
    const isSelected = i === parseInt(selectedBed);

    let bg, border, color2, content;
    if (isSelected) {
      bg='#d1fae5'; border='2px solid #059669'; color2='#065f46';
      content = '<div style="font-size:10px;font-weight:700;color:#059669;margin-bottom:3px">Lit '+i+'</div>'+
                '<div style="font-size:11px;font-weight:700;color:#065f46">← Nouveau</div>'+
                '<div style="font-size:9px;color:#059669">patient ici</div>';
    } else if (p) {
      const isHigh = p.risk==='ÉLEVÉ';
      const isMid = p.risk==='MOYEN';
      bg = isHigh?'#fee2e2':isMid?'#fef3c7':'#dbeafe';
      border = isHigh?'1.5px solid #fca5a5':isMid?'1.5px solid #fcd34d':'1.5px solid #93c5fd';
      color2 = isHigh?'#991b1b':isMid?'#92400e':'#1e40af';
      content = '<div style="font-size:9px;opacity:.7;margin-bottom:2px">Lit '+i+'</div>'+
                '<div style="font-size:10px;font-weight:600">'+p.gender+'·'+p.age+'a</div>'+
                '<div style="font-size:9px;opacity:.8">'+p.diagnosis.substring(0,8)+'</div>';
    } else {
      bg='#f0fdf4'; border='1.5px solid #86efac'; color2='#166534';
      content = '<div style="font-size:9px;opacity:.7;margin-bottom:2px">Lit '+i+'</div>'+
                '<div style="font-size:11px;color:#16a34a;font-weight:600">Libre</div>';
    }

    cell.style.cssText = 'background:'+bg+';border:'+border+';border-radius:8px;padding:7px 4px;text-align:center;color:'+color2+';min-height:62px;display:flex;flex-direction:column;align-items:center;justify-content:center;'+(isSelected?'box-shadow:0 0 0 3px #059669;transform:scale(1.06);':'');
    cell.innerHTML = content;
    grid.appendChild(cell);
  }

  mapCard.style.display = 'block';
  mapCard.style.borderLeftColor = color;
  setTimeout(()=>mapCard.scrollIntoView({behavior:'smooth', block:'nearest'}), 80);
}

