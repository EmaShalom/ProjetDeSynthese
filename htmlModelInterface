// ============ NAV ============
function showPanel(id) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  const titles = {dashboard:'Vue d\'ensemble',coordinator:'Coordonnateur',urgence:'Urgence',etage:'Étage — Gestion des lits',etagedisplay:'Affichage mural — Étage',hygiene:'Hygiène & salubrité',station:'Station matinale',ia:'Intelligence artificielle',transferts:'Transferts & Rapatriements',rapports:'Centre de rapports',admissions:'Admissions & Dossiers patients'};
  document.getElementById('topbar-title').textContent = titles[id] || id;
  event && event.currentTarget && event.currentTarget.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => {
    if (n.getAttribute('onclick') && n.getAttribute('onclick').includes("'"+id+"'")) n.classList.add('active');
  });
  // Special: refresh etage display when switching to it
  if (id === 'etagedisplay') { setTimeout(initEtageDisplay, 80); }
}

// ============ HELPERS ============
function riskBadge(r) {
  if (r === 'ÉLEVÉ') return '<span class="badge risk-high">● ÉLEVÉ</span>';
  if (r === 'MOYEN') return '<span class="badge risk-mid">● MOYEN</span>';
  return '<span class="badge risk-low">● FAIBLE</span>';
}
function statusBadge(s, outcome) {
  if (s === 'ADMITTED') return '<span class="badge badge-blue">Hospitalisé</span>';
  if (outcome === 'EXPIRY') return '<span class="badge badge-red">Décédé</span>';
  if (outcome === 'DAMA') return '<span class="badge badge-amber">DAMA</span>';
  return '<span class="badge badge-gray">Congé</span>';
}

// ============ STRETCHERS ============
function renderStretchers() {
  const sorted = [...SIM.waiting].sort((a,b) => {
    const rv = {ÉLEVÉ:3,MOYEN:2,FAIBLE:1};
    return rv[b.risk] - rv[a.risk] || b.wait_hours - a.wait_hours;
  });
  const grid = document.getElementById('stretcher-grid');
  grid.innerHTML = sorted.map(p => {
    const rClass = p.risk==='ÉLEVÉ'?'risk-high-card':p.risk==='MOYEN'?'risk-mid-card':'risk-low-card';
    const wClass = p.wait_hours >= 12 ? 'long' : '';
    return `<div class="stretcher-card ${rClass}">
      <div class="stretcher-num">Civière #${p.stretcher} · MRD-${p.id}</div>
      <div class="stretcher-patient">${p.gender === 'M' ? '👨' : '👩'} ${p.age} ans</div>
      <div class="stretcher-info">${p.diagnosis}<br>${p.target_unit_name}</div>
      <div>${riskBadge(p.risk)}</div>
      <div class="stretcher-wait ${wClass}" style="margin-top:6px">⏱ ${p.wait_hours}h d'attente</div>
      ${p.assignedBed ?
        `<div style="margin-top:6px;background:#0d2316;border:1px solid #3fb950;border-radius:6px;padding:5px 8px;font-size:12px;font-weight:700;color:#3fb950;text-align:center">✅ Lit ${p.assignedBed} attribué (${p.assignedAt})</div>` :
        `<button class="stretcher-action" onclick="assignBed(${p.id})">Attribuer un lit →</button>`
      }
    </div>`;
  }).join('');

  // Table
  const table = document.getElementById('waiting-table');
  table.innerHTML = `<thead><tr>
    <th>Civière</th><th>MRD</th><th>Âge</th><th>Diagnostic</th><th>Risque</th><th>Attente</th><th>Unité cible</th><th>Action</th>
  </tr></thead><tbody>` +
  sorted.map(p => `<tr>
    <td class="mono">#${p.stretcher}</td>
    <td class="mono">${p.id}</td>
    <td>${p.age} ans</td>
    <td>${p.diagnosis}</td>
