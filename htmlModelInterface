// ============ BED GRID ============
function renderBedGrid(unit) {
  const unitPatients = SIM.patients.filter(p => p.unit === unit && p.status === 'ADMITTED');
  const bedMap = {};
  unitPatients.forEach(p => bedMap[p.bed] = p);
  const total = SIM.units[unit].beds;
  const grid = document.getElementById('bed-grid');
  grid.innerHTML = '';
  for (let i = 1; i <= total; i++) {
    const p = bedMap[i];
    const cell = document.createElement('div');
    if (p) {
      const rCls = p.risk==='ÉLEVÉ'?'risk-high':p.risk==='MOYEN'?'risk-mid':'';
      cell.className = `bed-cell occupied ${rCls}`;
      const dotCls = p.risk==='ÉLEVÉ'?'high':p.risk==='MOYEN'?'mid':'low';
      cell.innerHTML = `<div class="risk-dot ${dotCls}"></div><div class="bed-num">Lit ${i}</div><div class="bed-name">${p.gender}·${p.age}a</div><div class="bed-diag">${p.diagnosis.substring(0,12)}</div>`;
      cell.onclick = () => showPatientModal(p);
    } else {
      cell.className = 'bed-cell available';
      cell.innerHTML = `<div class="bed-num">Lit ${i}</div><div class="bed-name" style="color:#16a34a">Disponible</div>`;
    }
    grid.appendChild(cell);
  }
}

