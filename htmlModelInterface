  '3N': SIM.waiting.filter(w => w.target_unit === '3N'),
  '3S': SIM.waiting.filter(w => w.target_unit === '3S'),
};
const UNIT_NAMES = {'2N':'2e Nord — Cardiologie','2S':'2e Sud — Soins intensifs','3N':'3e Nord — Néphrologie','3S':'3e Sud — Médecine gén.'};

function switchUnit(unit, tab) {
  currentUnit = unit;
  document.querySelectorAll('.unit-tab').forEach(t => t.classList.remove('active'));
  tab.classList.add('active');
  renderBedGrid(unit);
  renderUnitTable(unit);
  renderIncoming(unit);
