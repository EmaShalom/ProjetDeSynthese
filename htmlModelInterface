  const section = document.getElementById('adm-section-'+prefix);
  if (!section) return;
  section.querySelectorAll('input:not([readonly]), select, textarea').forEach(el => {
    if (el.type==='checkbox') el.checked=false;
    else if (el.tagName==='SELECT') el.selectedIndex=0;
    else el.value='';
  });
  if (prefix==='etg') {
    const occWrap = document.getElementById('etg-occ-bar-wrap');
    if (occWrap) occWrap.style.display='none';
  }
}

// ── RECHERCHE & MODIFICATION DOSSIERS ──
let currentEditPatient = null;

function filterPatientSearch() {
  const mrd = (document.getElementById('search-mrd')||{value:''}).value.toLowerCase();
  const nom = (document.getElementById('search-nom')||{value:''}).value.toLowerCase();
  const unite = (document.getElementById('search-unite')||{value:''}).value;
  const statut = (document.getElementById('search-statut')||{value:''}).value;
  const results = SIM.patients.filter(p => {
    if (mrd && !String(p.id).includes(mrd)) return false;
    if (nom && !('patient-'+p.id).toLowerCase().includes(nom) && !String(p.id).includes(nom)) return false;
    if (unite && p.unit!==unite) return false;
    if (statut && p.status!==statut) return false;
    return true;
  });
  const table = document.getElementById('search-results-table');
  if (!table) return;
  if (results.length===0) {
    table.innerHTML='<tr><td colspan="7" style="padding:16px;text-align:center;color:var(--text3);font-style:italic">Aucun résultat trouvé</td></tr>';
    return;
  }
  table.innerHTML = `<thead><tr>
    <th>MRD</th><th>Âge / Sexe</th><th>Diagnostic</th><th>Unité · Lit</th><th>Admission</th><th>Statut</th><th>Action</th>
  </tr></thead><tbody>` +
  results.slice(0,25).map(p=>`<tr>
    <td class="mono">${p.id}</td>
    <td>${p.age}a · ${p.gender==='M'?'H':'F'}</td>
    <td>${p.diagnosis}</td>
    <td><span class="badge badge-blue">${p.unit}</span> Lit ${p.bed}</td>
    <td>${p.admit_date}</td>
    <td>${p.status==='ADMITTED'?'<span class="badge badge-blue">Hospitalisé</span>':'<span class="badge badge-gray">Congé</span>'}</td>
    <td><button class="btn btn-primary btn-sm" onclick='openEditPatient(${JSON.stringify(p)})'>✏️ Modifier</button></td>
  </tr>`).join('') + '</tbody>';
}

function openEditPatient(p) {
  currentEditPatient = {...p};
  document.getElementById('edit-patient-card').style.display='block';
  document.getElementById('edit-patient-title').textContent = '✏️ Modifier le dossier — MRD-'+p.id;
  document.getElementById('edit-patient-mrd').textContent = 'MRD-'+p.id+' · '+p.age+'a · '+p.unit;
  // Identité
  document.getElementById('edit-nom').value = 'Patient-'+p.id;
  document.getElementById('edit-prenom').value = '';
  document.getElementById('edit-ddn').value = '';
  document.getElementById('edit-sexe').value = p.gender;
  document.getElementById('edit-ramq').value = '';
  document.getElementById('edit-adresse').value = '';
  document.getElementById('edit-tel').value = '';
  document.getElementById('edit-contact-nom').value = '';
  document.getElementById('edit-contact-tel').value = '';
  // Clinique
  document.getElementById('edit-diag').value = p.diagnosis;
  document.getElementById('edit-dm').checked = p.dm===1;
  document.getElementById('edit-htn').checked = p.htn===1;
  document.getElementById('edit-ckd').checked = false;
  document.getElementById('edit-smoking').checked = p.smoking===1;
  document.getElementById('edit-alcohol').checked = false;
  document.getElementById('edit-notes').value = '';
  // Séjour
  document.getElementById('edit-unite').value = p.unit;
  document.getElementById('edit-lit').value = p.bed;
  document.getElementById('edit-statut').value = p.status;
  document.getElementById('edit-admit-date').value = p.admit_date;
  document.getElementById('edit-discharge-date').value = p.discharge_date;
  document.getElementById('edit-outcome').value = p.outcome;
  document.getElementById('edit-medecin').value = '';
  document.getElementById('edit-icu').value = p.icu_days||0;
  // Biologiques
  document.getElementById('edit-hb').value = p.hb||'';
  document.getElementById('edit-glucose').value = p.glucose||'';
  document.getElementById('edit-creatinine').value = p.creatinine||'';
  document.getElementById('edit-urea').value = '';
  document.getElementById('edit-platelets').value = '';
  document.getElementById('edit-ef').value = p.ef||'';
  document.getElementById('edit-tlc').value = '';
  document.getElementById('edit-bnp').value = '';
  document.getElementById('edit-bio-date').value = '';
  editSwitchTab('identite');
  setTimeout(()=>document.getElementById('edit-patient-card').scrollIntoView({behavior:'smooth'}),100);
}

function editSwitchTab(tab) {
  ['identite','clinique','sejour','biologiques'].forEach(t=>{
    const s=document.getElementById('edit-section-'+t);
    const tb=document.getElementById('edit-tab-'+t);
    if(s) s.style.display=t===tab?'grid':'none';
    if(tb){tb.style.color=t===tab?'var(--blue)':'var(--text2)';tb.style.borderBottomColor=t===tab?'var(--blue)':'transparent';}
  });
}

function closeEditCard() {
  document.getElementById('edit-patient-card').style.display='none';
  currentEditPatient=null;
}

function savePatientEdit() {
  if (!currentEditPatient) return;
  const idx = SIM.patients.findIndex(p=>p.id===currentEditPatient.id);
  if (idx>=0) {
    const g=document.getElementById('edit-sexe').value; if(g) SIM.patients[idx].gender=g;
    const d=document.getElementById('edit-diag').value; if(d) SIM.patients[idx].diagnosis=d;
    const u=document.getElementById('edit-unite').value; if(u) SIM.patients[idx].unit=u;
    const l=parseInt(document.getElementById('edit-lit').value); if(l) SIM.patients[idx].bed=l;
    const s=document.getElementById('edit-statut').value; if(s) SIM.patients[idx].status=s;
    const ad=document.getElementById('edit-admit-date').value; if(ad) SIM.patients[idx].admit_date=ad;
    const dd=document.getElementById('edit-discharge-date').value; if(dd) SIM.patients[idx].discharge_date=dd;
    const oc=document.getElementById('edit-outcome').value; if(oc) SIM.patients[idx].outcome=oc;
    const ic=parseInt(document.getElementById('edit-icu').value); if(!isNaN(ic)) SIM.patients[idx].icu_days=ic;
    const hb=parseFloat(document.getElementById('edit-hb').value); if(!isNaN(hb)) SIM.patients[idx].hb=hb;
    const gl=parseInt(document.getElementById('edit-glucose').value); if(!isNaN(gl)) SIM.patients[idx].glucose=gl;
    const cr=parseFloat(document.getElementById('edit-creatinine').value); if(!isNaN(cr)) SIM.patients[idx].creatinine=cr;
    const ef=parseFloat(document.getElementById('edit-ef').value); if(!isNaN(ef)) SIM.patients[idx].ef=ef;
    SIM.patients[idx].dm=document.getElementById('edit-dm').checked?1:0;
    SIM.patients[idx].htn=document.getElementById('edit-htn').checked?1:0;
    SIM.patients[idx].smoking=document.getElementById('edit-smoking').checked?1:0;
  }
    alert('\u2705 Dossier MRD-'+currentEditPatient.id+' mis a jour avec succes !\nLes modifications sont visibles dans tous les ecrans.');
  filterPatientSearch();
  renderBedGrid(SIM.patients[SIM.patients.findIndex(p=>p.id===currentEditPatient.id)]?.unit || currentEditPatient.unit);
  closeEditCard();
}











// ===== ATTRIBUTION SYSTÈME =====
if (!SIM.attributions) SIM.attributions = []; // {id, unit, bed, stretcher, diagnosis, risk, age, gender, assignedAt}

function doAssignBed(id) {
  var p = SIM.waiting.find(function(w){ return w.id===id; });
  if (!p) return;
  var unit = p.target_unit;

  // Find first free bed not already assigned
  var occupied = SIM.patients.filter(function(x){ return x.unit===unit&&x.status==='ADMITTED'; }).map(function(x){return x.bed;});
  var assigned  = SIM.attributions.filter(function(a){ return a.unit===unit; }).map(function(a){return a.bed;});
  var freeBed = null;
  for (var i=1;i<=15;i++){
    if (!occupied.includes(i) && !assigned.includes(i)){ freeBed=i; break; }
  }
  if (!freeBed){ alert('Aucun lit disponible dans cette unite.'); return; }

  // Store attribution
  var now = new Date();
  var timeStr = now.toLocaleTimeString('fr-CA',{hour:'2-digit',minute:'2-digit'});
  SIM.attributions.push({
    id: p.id, unit: unit, unitName: p.target_unit_name,
    bed: freeBed, stretcher: p.stretcher,
    diagnosis: p.diagnosis, risk: p.risk,
    age: p.age, gender: p.gender,
    assignedAt: timeStr, assignedTs: now.getTime()
  });

  // Update civière card — show assigned bed
  p.assignedBed = freeBed;
  p.assignedAt  = timeStr;

  // Refresh urgence + etage display
  renderStretchers();
  if (document.getElementById('ed-grid')) edRender();

  // Toast notification
  edShowToast('Attribution confirmee', 'Civiere #'+p.stretcher+' -> Lit '+freeBed+' ('+p.target_unit_name+')', '#3fb950');

  alert('Attribution confirmee!\n\nCiviere #'+p.stretcher+' -> Lit '+freeBed+'\nUnite: '+p.target_unit_name+'\nPatient MRD-'+p.id+'\n\nL\'etage a ete notifie automatiquement.');
}

function edShowToast(title, msg, color) {
  var t = document.createElement('div');
  t.style.cssText = 'position:fixed;bottom:20px;right:20px;background:#161b22;border:2px solid '+color+';border-radius:10px;padding:12px 16px;z-index:9999;font-size:13px;color:#e6edf3;max-width:300px;box-shadow:0 4px 20px rgba(0,0,0,.4);animation:ed-slidein .3s ease-out;font-family:DM Sans,sans-serif';
  t.innerHTML = '<div style="font-weight:700;color:'+color+';margin-bottom:4px">'+title+'</div><div style="color:#8b949e">'+msg+'</div>';
  document.body.appendChild(t);
  setTimeout(function(){ t.style.opacity='0'; t.style.transition='opacity .4s'; setTimeout(function(){t.remove();},400); }, 4000);
}

// ===== AFFICHAGE MURAL ETAGE =====
var ED_UNIT = '2N';
var ED_CD = 30;
var ED_CLOCK_IV = null;
var ED_CD_IV = null;
var ED_META = {
  '2N':{name:'2e Nord - Cardiologie'},
  '2S':{name:'2e Sud - Soins intensifs'},
  '3N':{name:'3e Nord - Nephrologie'},
  '3S':{name:'3e Sud - Medecine gen.'}
};

function edRender() {
  var grid = document.getElementById('ed-grid');
  if (!grid) return;
  var unit = ED_UNIT;

  var unEl = document.getElementById('ed-uname');
  if (unEl) unEl.textContent = ED_META[unit].name;

  var admitted  = SIM.patients.filter(function(p){ return p.unit===unit&&p.status==='ADMITTED'; });
  var bedMap    = {};
  admitted.forEach(function(p){ bedMap[p.bed]=p; });

  // Attribution map for this unit
  var attrMap = {};
  (SIM.attributions||[]).filter(function(a){ return a.unit===unit; }).forEach(function(a){ attrMap[a.bed]=a; });

  // Free beds = not occupied AND not attributed
  var freeBeds = [];
  for (var i=1;i<=15;i++){
    if (!bedMap[i] && !attrMap[i]) freeBeds.push(i);
  }

  var fEl=document.getElementById('ed-free');
  var oEl=document.getElementById('ed-occ');
  if(fEl) fEl.textContent=freeBeds.length+' libres';
  if(oEl) oEl.textContent=admitted.length+' occupes';

  // ── GRILLE ──
  grid.innerHTML='';
  for(var n=1;n<=15;n++){
    var p=bedMap[n]; var attr=attrMap[n];
    var cell=document.createElement('div');
    if(attr){
      // Lit attribué — en attente d'arrivée
      cell.className='edc ed-assigned';
      var rc=attr.risk==='ELEVE'||attr.risk==='ÉLEVÉ'?'h':attr.risk==='MOYEN'?'m':'l';
      cell.innerHTML='<div class="ed-abadge">ATTRIBUE</div>'+
        '<div class="ed-bnum">LIT '+n+'</div>'+
        '<div class="ed-bname">Civ. #'+attr.stretcher+'</div>'+
        '<div class="ed-bdet">MRD-'+attr.id+'<br>'+(attr.gender==='M'?'H':'F')+' - '+attr.age+' ans</div>'+
        '<div class="ed-bdiag">'+attr.diagnosis+'</div>'+
        '<div style="font-size:9px;color:#bc8cff;margin-top:2px">'+attr.assignedAt+'</div>';
    } else if(p){
      var r=p.risk||'FAIBLE';
      cell.className='edc '+(r==='ÉLEVÉ'||r==='ELEVE'?'ed-high':r==='MOYEN'?'ed-mid':'ed-occ');
      var dc=r==='ÉLEVÉ'||r==='ELEVE'?'h':r==='MOYEN'?'m':'l';
      cell.innerHTML='<div class="ed-dot '+dc+'"></div>'+
        '<div class="ed-bnum">LIT '+n+'</div>'+
        '<div class="ed-bname">MRD-'+p.id+'</div>'+
        '<div class="ed-bdet">'+(p.gender==='M'?'H':'F')+' - '+p.age+' ans</div>'+
        '<div class="ed-bdiag">'+p.diagnosis+'</div>';
    } else {
      cell.className='edc ed-free';
      cell.innerHTML='<div class="ed-bnum">LIT '+n+'</div>'+
        '<div style="font-size:18px;margin:4px 0">&#x1F6CF;</div>'+
        '<div style="font-size:11px;font-weight:700;color:#3fb950">LIBRE</div>';
    }
    grid.appendChild(cell);
  }

  // ── LISTE LITS LIBRES ──
  var flEl=document.getElementById('ed-freelist');
  if(flEl){
    if(freeBeds.length===0){
      flEl.innerHTML='<div style="font-size:11px;color:#484f58;padding:10px 0">Aucun lit disponible</div>';
    } else {
      flEl.innerHTML=freeBeds.map(function(n){
        return '<div class="ed-freeitem">'+
          '<span class="ed-fn">Lit '+n+'</span>'+
          '<span class="ed-fs">Disponible</span>'+
        '</div>';
      }).join('');
    }
  }

  // ── NOTIFICATIONS ──
  var notifList=document.getElementById('ed-notif-list');
  var notifEmpty=document.getElementById('ed-notif-empty');
  var notifDot=document.getElementById('ed-notif-dot');
  var attribs=(SIM.attributions||[]).filter(function(a){return a.unit===unit;})
    .sort(function(a,b){return b.assignedTs-a.assignedTs;});

  if(!notifList) return;
  if(attribs.length===0){
    if(notifEmpty) notifEmpty.style.display='block';
    if(notifDot) notifDot.style.display='none';
    notifList.innerHTML='';
  } else {
    if(notifEmpty) notifEmpty.style.display='none';
    if(notifDot) notifDot.style.display='inline-block';
    var rc2={'ÉLEVÉ':'h','ELEVE':'h','MOYEN':'m','FAIBLE':'l'};
    notifList.innerHTML=attribs.map(function(a){
      var rc=rc2[a.risk]||'l';
      return '<div class="ed-notif-card">'+
        '<div class="ed-nc-bell">&#x1F514;</div>'+
        '<div class="ed-nc-title">Civiere #'+a.stretcher+' -> Lit '+a.bed+'</div>'+
        '<div class="ed-nc-lit">LIT '+a.bed+'</div>'+
        '<div class="ed-nc-row"><span class="ed-nc-lbl">Patient</span><span class="ed-nc-val">MRD-'+a.id+'</span></div>'+
        '<div class="ed-nc-row"><span class="ed-nc-lbl">Age/Sexe</span><span class="ed-nc-val">'+a.age+'a - '+(a.gender==='M'?'H':'F')+'</span></div>'+
        '<div class="ed-nc-row"><span class="ed-nc-lbl">Diagnostic</span><span class="ed-nc-val">'+a.diagnosis+'</span></div>'+
        '<div class="ed-nc-row"><span class="ed-nc-lbl">Risque</span><span class="ed-nc-val ed-risk '+rc+'">'+a.risk+'</span></div>'+
        '<div class="ed-nc-time">Attribue a '+a.assignedAt+'</div>'+
      '</div>';
    }).join('');
  }
}

function edClock(){
  var c=document.getElementById('ed-clock');
  var d=document.getElementById('ed-dlbl');
  if(!c)return;
  var now=new Date();
  c.textContent=now.toLocaleTimeString('fr-CA',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  if(d) d.textContent=now.toLocaleDateString('fr-CA',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
}

function edCountdown(){
  var el=document.getElementById('ed-cd');
  if(!el)return;
  ED_CD--;
  if(ED_CD<=0){ED_CD=30;edRender();}
  el.textContent=ED_CD;
}

function edSwitch(unit,btn){
  ED_UNIT=unit;
  document.querySelectorAll('.ed-ubtn').forEach(function(b){b.classList.remove('active');});
  if(btn)btn.classList.add('active');
  edRender();
}

function initEtageDisplay(){
  edRender();
  if(!ED_CLOCK_IV){edClock();ED_CLOCK_IV=setInterval(edClock,1000);}
  if(!ED_CD_IV){ED_CD_IV=setInterval(edCountdown,1000);}
}

