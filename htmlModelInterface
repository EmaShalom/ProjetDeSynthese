}

function updateEtageKpis(unit) {
  const pts = SIM.patients.filter(p => p.unit === unit);
  const admitted = pts.filter(p => p.status === 'ADMITTED');
  const free = 15 - admitted.length;
  const highRisk = admitted.filter(p => p.risk === 'ÉLEVÉ').length;
  const incoming = UNIT_INCOMING[unit] || [];
  const discharging = admitted.filter(p => {
    const d = new Date(p.discharge_date);
    const tomorrow = new Date('2025-04-14');
    return d <= tomorrow;
  }).length;
  document.getElementById('kpi-occupied').textContent = admitted.length;
  document.getElementById('kpi-free').textContent = free;
  document.getElementById('kpi-incoming').textContent = incoming.length;
  document.getElementById('kpi-highrisk').textContent = highRisk;
  document.getElementById('kpi-discharge').textContent = discharging;
  document.getElementById('unit-patient-title').textContent = 'Patients hospitalisés — ' + UNIT_NAMES[unit];
  document.getElementById('unit-admitted-count').textContent = admitted.length + ' présents';
  document.getElementById('unit-discharged-count').textContent = (pts.length - admitted.length) + ' congés semaine';
}

function renderIncoming(unit) {
  const incoming = UNIT_INCOMING[unit] || [];
  const el = document.getElementById('incoming-list');
  const unitName = UNIT_NAMES[unit];
  document.getElementById('incoming-unit-name').textContent = unitName;
  document.getElementById('incoming-badge').textContent = incoming.length + ' arrivée' + (incoming.length > 1 ? 's' : '') + ' prévue' + (incoming.length > 1 ? 's' : '');
  if (incoming.length === 0) {
    el.innerHTML = '<div style="padding:16px 18px;font-size:13px;color:var(--text3);font-style:italic">✅ Aucune arrivée en attente pour cette unité.</div>';
    return;
  }
  const sorted = [...incoming].sort((a,b) => {
    const rv = {ÉLEVÉ:3,MOYEN:2,FAIBLE:1};
    return rv[b.risk] - rv[a.risk] || b.wait_hours - a.wait_hours;
  });
  el.innerHTML = sorted.map(p => {
    const rBg = p.risk==='ÉLEVÉ'?'#fff5f5':p.risk==='MOYEN'?'#fffbeb':'#f0fdf4';
    const rBorder = p.risk==='ÉLEVÉ'?'#fca5a5':p.risk==='MOYEN'?'#fcd34d':'#86efac';
    const rColor = p.risk==='ÉLEVÉ'?'#991b1b':p.risk==='MOYEN'?'#92400e':'#166534';
    return `<div style="display:flex;align-items:center;gap:14px;padding:12px 18px;border-bottom:1px solid var(--border);background:${rBg}">
      <div style="width:6px;height:6px;border-radius:50%;background:${rColor};flex-shrink:0"></div>
      <div style="flex:1">
        <div style="font-size:13px;font-weight:600;color:var(--text)">MRD-${p.id} · ${p.gender === 'M' ? 'Homme' : 'Femme'} ${p.age} ans</div>
        <div style="font-size:12px;color:var(--text2);margin-top:2px">Diagnostic : <strong>${p.diagnosis}</strong> · Civière #${p.stretcher}</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:11px;font-weight:600;background:${rBg};color:${rColor};border:1px solid ${rBorder};padding:3px 8px;border-radius:4px">${p.risk === 'ÉLEVÉ' ? '● ÉLEVÉ' : p.risk === 'MOYEN' ? '● MOYEN' : '● FAIBLE'}</div>
        <div style="font-size:10px;color:var(--text3);margin-top:3px">Attente: ${p.wait_hours}h</div>
